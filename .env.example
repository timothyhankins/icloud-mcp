# iCloud credentials (fallback if not provided in headers)
ICLOUD_EMAIL=your-email@icloud.com
ICLOUD_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# iCloud servers (default values for iCloud)
CALDAV_SERVER=https://caldav.icloud.com
CARDDAV_SERVER=https://contacts.icloud.com
IMAP_SERVER=imap.mail.me.com
SMTP_SERVER=smtp.mail.me.com

# Server configuration
MCP_SERVER_PORT=8000
IMAP_PORT=993
SMTP_PORT=587

# OAuth / MCP auth (required for Railway / Claude.ai connector)
MCP_AUTH_TOKEN=   # Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_AUTH_PIN=     # Short PIN for OAuth authorize step
MCP_BASE_URL=     # e.g. https://icloud-mcp-production.up.railway.app
MCP_TRANSPORT=sse # Set to "sse" for Railway deployment
